# Server
PORT=8080
NODE_ENV=development

# ============================================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL_TRANSACTION_POOLER=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# Optional direct connection for troubleshooting only.
# DATABASE_URL_DIRECT=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://yteskfhjcpqujrgkfmpr.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_SECRET_KEY=your_secret_key_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ============================================================================
# SESSION & SECURITY
# ============================================================================
